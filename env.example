# IFC/BIM Visual Compliance Checker environment configuration.
# Copy this template to .env and add the local credentials.

# OpenRouter API key for VLM-based visual compliance checking.
# OpenRouter keys are available at: https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=sk-your-openrouter-key-here

# OpenAI API key for the alternate provider.
# VITE_OPENAI_API_KEY=sk-openai-key-placeholder

# Web Fetch proxy used by WEB_FETCH for regulatory documents.
# The current allowlist is intended for codes.iccsafe.org.
# VITE_WEB_FETCH_PROXY_URL=https://regulatory-fetch.example.workers.dev

# Tavily API key for regulatory code search.
# Tavily keys are available at: https://tavily.com
# When configured, Tavily search can supplement WEB_FETCH
# for finding regulatory code sections, building standards, and compliance references.
#VITE_TAVILY_API_KEY=tvly-key-placeholder

# Application display settings.
# VITE_APP_TITLE=IFC BIM Visual Compliance Checker
# VITE_APP_VERSION=1.0.0
